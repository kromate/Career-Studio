# Local mode works without credentials and stores data in this browser.
NUXT_PUBLIC_APP_MODE=local

# Use the same Firebase web app/project as Goalmatic for shared user identity.
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=

# Optional Goalmatic email OTP endpoint and central application URL.
NUXT_PUBLIC_GOALMATIC_OTP_URL=
NUXT_PUBLIC_GOALMATIC_APP_URL=https://goalmatic.io
