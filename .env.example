# Local mode works without credentials and stores data in this browser.
VITE_APP_MODE=local

# Use the same Firebase web app/project as Goalmatic for shared user identity.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_DATABASE_ID=career-studio
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Central Goalmatic application URL.
VITE_GOALMATIC_APP_URL=https://goalmatic.io

# Optional: enables AI-assisted structuring when importing existing resumes.
# The key is read only by the Nuxt server and is never exposed to the browser.
VITE_GEMINI_API_KEY=

# Optional: enables importing job descriptions from public job posting URLs.
# The key is read only by the Nuxt server and is never exposed to the browser.
VITE_TABSTACK_API_KEY=
